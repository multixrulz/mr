correct: true
@answer
text: AA
correct: false
@answer
text: A
correct: false
@answer
text: Aa
correct: false

% multichoice
text: What are the genotypes of the parents in this punnett square?
image: genetics/punnett-AA-Aa-complete.svg
@answer
text: AA and Aa
correct: true
@answer
text: A and a
correct: false
@answer
text: A, A and b
correct: false
@answer
text: AA, AA, Aa and Aa
correct: false

% multichoice
text: The A allele produces airy sponges while the a allele produces dense sponges. What phenotype does the Aa genotype produce
