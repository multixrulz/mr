% jquiz
% multichoice
text: Which allele is dominant in this punnett square?
image: genetics/punnett-AA-Aa-complete.svg
@answer
text: A
correct: true
@answer
text: AA
correct: false
@answer
text: a
correct: false
@answer
text: Aa
correct: false

% multichoice
